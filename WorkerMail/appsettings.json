{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConsoleLogging": {
    "TimestampFormat": "[HH:mm:ss] ",
    "SingleLine": true
  },
  "CoreLog": {
    "Enabled": true,
    "ApplicationName": "WorkerMail",
    "SourceType": "Worker",
    "BootstrapServers": "localhost:9092",
    "TopicName": "application.logs",
    "ProducerClientId": "worker-mail-log-producer",
    "AdminClientId": "worker-mail-log-admin",
