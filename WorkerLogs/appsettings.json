{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConsoleLogging": {
    "TimestampFormat": "[HH:mm:ss] ",
    "SingleLine": true
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "TopicName": "application.logs",
    "GroupId": "raims-worker-logs",
    "ConsumerClientId": "worker-logs-consumer-local",
    "AdminClientId": "worker-logs-admin-local",
    "AutoOffsetReset": "Earliest",
    "EnableAutoCommit": false,
    "ConsumerAllowAutoCreateTopics": false,
    "EnsureTopicOnStartup": true,
    "TopicProvisionRetryDelayMs": 3000,
    "TopicMetadataTimeoutMs": 5000,
    "SessionTimeoutMs": 45000,
    "SocketTimeoutMs": 30000,
    "TopicPartitions": 3,
    "TopicReplicationFactor": 1,
    "SecurityProtocol": "",
    "SaslMechanism": "",
    "SaslUsername": "",
    "SaslPassword": ""
  },
  "Worker": {
    "BatchSize": 10000,
    "FlushIntervalMs": 1000,
    "RetryDelayMs": 2000
  },
  "Storage": {
    "LogsDirectory": "Logs"
  }
}
