{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConsoleLogging": {
    "TimestampFormat": "[HH:mm:ss] ",
    "SingleLine": true
  },
  "CoreLog": {
    "Enabled": true,
    "ApplicationName": "WorkerMail",
    "SourceType": "Worker",
    "BootstrapServers": "localhost:9092",
    "TopicName": "application.logs",
    "ProducerClientId": "worker-mail-log-producer",
    "AdminClientId": "worker-mail-log-admin",
    "EnsureTopicOnStartup": true,
    "TopicPartitions": 3,
    "TopicReplicationFactor": 1,
    "TopicMetadataTimeoutMs": 5000,
    "SocketTimeoutMs": 30000,
    "SecurityProtocol": "",
    "SaslMechanism": "",
    "SaslUsername": "",
    "SaslPassword": ""
  },
  "Redis": {
    "Host": "localhost",
    "Port": 6379,
    "Database": 0,
    "ConnectRetry": 100,
    "AbortOnConnectFail": false,
    "ReconnectRetryDelayMs": 5000,
    "ConnectTimeoutMs": 5000,
    "AsyncTimeoutMs": 5000,
    "KeepAliveSeconds": 5,
    "AllowAdmin": false,
    "ClientName": "WorkerMail",
    "LockKeyPrefix": "worker-mail:lock:",
    "AttemptKeyPrefix": "worker-mail:attempt:",
    "ProcessedKeyPrefix": "worker-mail:processed:",
    "LastEventKeyPrefix": "worker-mail:last-event:",
    "Password": ""
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "raims-worker-mail",
    "RequestTopic": "email.send.requested",
    "DeadLetterTopic": "email.send.deadletter",
    "ConsumerClientId": "worker-mail-consumer-local",
    "ProducerClientId": "worker-mail-producer-local",
    "AdminClientId": "worker-mail-admin-local",
    "AutoOffsetReset": "Earliest",
    "EnableAutoCommit": false,
    "ConsumerAllowAutoCreateTopics": false,
    "ProducerAllowAutoCreateTopics": false,
    "EnsureTopicsOnStartup": true,
    "TopicProvisionRetryDelayMs": 3000,
    "TopicMetadataTimeoutMs": 5000,
    "SessionTimeoutMs": 45000,
    "SocketTimeoutMs": 30000,
    "RequestTopicPartitions": 3,
    "DeadLetterTopicPartitions": 3,
    "RequestTopicReplicationFactor": 1,
    "DeadLetterTopicReplicationFactor": 1,
    "SecurityProtocol": "",
    "SaslMechanism": "",
    "SaslUsername": "",
    "SaslPassword": ""
  },
  "Smtp": {
    "Host": "smtp.seudominio.com",
    "Port": 587,
    "Username": "usuario-smtp",
    "Password": "senha-smtp",
    "EnableSsl": true,
    "UseDefaultCredentials": false,
    "FromEmail": "naoresponda@seudominio.com",
    "FromName": "Raims",
    "ReplyToEmail": "suporte@seudominio.com",
    "ReplyToName": "Suporte Raims",
